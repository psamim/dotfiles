DISABLE_AUTO_TITLE="true"
function set_tmux_title {
  if [[ -n "$SSH_CONNECTION" ]]; then
    # SSH session: show user@host:cwd
    print -Pn "\e]2;%n@%m:%~\a"
  else
    print -Pn "\e]2;%20<..<%~%<<\a"
  fi
}
precmd_functions+=(set_tmux_title)
